@{
    ViewData["Title"] = "Home Page";
}

<div class="full-hero hero-1">
    <div class="hero-content">
        <h1 class="japanese-title">Japanese cuisine</h1>
        <div class="slogan-wrapper">
            <img src="~/images/flower.png" class="sakura-icon" alt="sakura" />
            <span class="slogan-text">Справжня Японія. Без зайвих слів.</span>
        </div>
    </div>
</div>

<div id="discounts" class="discount-container">
    <div class="discount-image-full">
        <img src="~/images/photo2.png" alt="Discount" />
    </div>

    <div class="discount-text-wrapper">
        <h2 class="discount-label">Discount</h2>
    </div>
</div>

<style>
    
    body {
        background-color: #212023 !important;
        margin: 0;
        padding: 0;
        overflow-x: hidden;
    }

    
    .full-hero {
        height: 100vh;
        width: 100vw;
        margin-left: calc(-50vw + 50%);
        margin-top: -65px;
        background: linear-gradient(rgba(0,0,0,0.2), rgba(0,0,0,0.4)), url('/images/photo1.png') no-repeat center center;
        background-size: cover;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    
    .discount-container {
        width: 100vw;
        margin-left: calc(-50vw + 50%);
        background-color: #212023;
    }

    
    .discount-image-full {
        width: 100%;
        line-height: 0; 
    }

        .discount-image-full img {
            width: 100%;
            height: auto;
            display: block;
        }

    
    .discount-text-wrapper {
        padding: 40px 0 80px 8%; 
    }

    .discount-label {
        font-family: 'KaiseiOpti', serif !important;
        color: #f8ccc3 !important;
        font-size: 8rem;
        margin: 0;
        font-weight: 400;
        letter-spacing: -2px;
    }

 
</style>
<div class="menu-list-section">
    <div class="promo-grid">
        
        <div class="promo-card">
            <div class="promo-image">
                <img src="~/images/ramen.png" alt="Ramen Tonkotsu" />
            </div>
            <div class="promo-info">
                <h3 class="promo-name">Ramen “Tonkotsu”</h3>
                <div class="price-block">
                    <span class="old-price">320₴</span>
                    <span class="current-price">279₴</span>
                </div>
                <div class="promo-footer">
                    <a asp-controller="Home" asp-action="Details" asp-route-dishName="ramen" class="more-link">more details</a>
                </div>
            </div>
        </div>

        <div class="promo-card">
            <div class="promo-image">
                <img src="~/images/set-philadelphia.png" alt="Set Philadelphia" />
            </div>
            <div class="promo-info">
                <h3 class="promo-name">Set “Philadelphia”</h3>
                <div class="price-block">
                    <span class="old-price">1500₴</span>
                    <span class="current-price">990₴</span>
                </div>
                <div class="promo-footer">
                    <a asp-controller="Home" asp-action="Details" asp-route-dishName="set" class="more-link">more details</a>
                </div>
            </div>
        </div>

        <div class="promo-card">
            <div class="promo-image">
                <img src="~/images/mochi.png" alt="Mochi Set" />
            </div>
            <div class="promo-info">
                <h3 class="promo-name">Mochi Set</h3>
                <div class="price-block">
                    <span class="old-price">400₴</span>
                    <span class="current-price">280₴</span>
                </div>
                <div class="promo-footer">
                    <a asp-controller="Home" asp-action="Details" asp-route-dishName="mochi" class="more-link">more details</a>
                </div>
            </div>
        </div>

        <div class="promo-card">
            <div class="promo-image">
                <img src="~/images/matcha (1).png" alt="Coffe Matcha" />
            </div>
            <div class="promo-info">
                <h3 class="promo-name">Coffe “Matcha”</h3>
                <div class="price-block">
                    <span class="old-price">1 + 1</span>
                    <span class="current-price">100₴</span>
                </div>
                <div class="promo-footer">
                    <a asp-controller="Home" asp-action="Details" asp-route-dishName="matcha" class="more-link">more details</a>
                </div>
            </div>
        </div>

    </div>
</div>

<style>
    .menu-list-section {
        background-color: #212023;
        width: 100vw;
        margin-left: calc(-50vw + 50%);
        padding: 80px 5%;
        box-sizing: border-box;
    }

    .promo-grid {
        display: grid;
        grid-template-columns: 1fr 1fr; 
        column-gap: 8%; 
        row-gap: 120px;
        max-width: 1600px;
        margin: 0 auto;
    }

    .promo-card {
        display: flex;
        align-items: center;
        gap: 40px;
        width: 100%;
    }

    .promo-image {
      
        flex: 0 0 350px;
        height: 350px;
    }

        .promo-image img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            filter: drop-shadow(0 20px 40px rgba(0,0,0,0.7));
        }

    .promo-info {
        flex: 1;
        color: #f8ccc3;
        font-family: 'KaiseiOpti', serif !important;
    }

    .promo-name {
        font-size: 3.2rem; 
        margin-bottom: 20px;
    }

    .price-block {
        margin-bottom: 30px;
    }
    
    .old-price {
        display: block;
        color: #555;
        
        text-decoration: none;
        font-size: 1.6rem;
        margin-bottom: 5px;
        font-family: 'KaiseiOpti', serif;
    }

    
    .promo-card:not(:last-child) .old-price {
        text-decoration: line-through;
    }

    .current-price {
        color: #b22222; 
        font-size: 2.2rem;
        font-weight: 400;
    }

    .current-price {
        color: #b22222; 
        font-size: 2.2rem;
        font-weight: 400;
    }

    .promo-footer {
        margin-top: auto;
        text-align: right; 
    }

    .more-link {
        color: #f8ccc3;
        text-decoration: none;
        font-size: 1.4rem;
        opacity: 0.7;
        transition: 0.3s;
    }

    .more-link:hover {
        opacity: 1;
        text-decoration: underline;
    }

   
   
</style>