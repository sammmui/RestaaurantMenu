@model RestaurantMenuDomain.Model.Review

@{
    ViewData["Title"] = "Create";
}

<style>
    /* Стиль для зірочок */
    .star-rating {
        display: flex;
        flex-direction: row-reverse;
        justify-content: flex-end;
        gap: 5px;
    }
    .star-rating input { display: none; }
    .star-rating label {
        font-size: 35px;
        color: #ccc;
        cursor: pointer;
        transition: color 0.2s;
    }
    .star-rating label:hover,
    .star-rating label:hover ~ label,
    .star-rating input:checked ~ label {
        color: #ffc107; 
    }
</style>

<h1>Create Review</h1>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" name="Productsid" value="@ViewBag.Productsid" />

            <div class="form-group mb-3">
                <label asp-for="Data" class="control-label">Дата</label>
                <input asp-for="Data" class="form-control" type="datetime-local" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
            </div>

            <div class="form-group mb-3">
                <label class="control-label">Ваша оцінка</label>
                <div class="star-rating">
                   
                    <input type="radio" id="star5" name="Mark" value="10" /><label for="star5">★</label>
                    <input type="radio" id="star4" name="Mark" value="8" /><label for="star4">★</label>
                    <input type="radio" id="star3" name="Mark" value="6" /><label for="star3">★</label>
                    <input type="radio" id="star2" name="Mark" value="4" /><label for="star2">★</label>
                    <input type="radio" id="star1" name="Mark" value="2" /><label for="star1">★</label>
                </div>
                <span asp-validation-for="Mark" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Comment" class="control-label">Ваш коментар</label>
                <textarea asp-for="Comment" class="form-control" rows="3" placeholder="Напишіть щось смачне..."></textarea>
                <span asp-validation-for="Comment" class="text-danger"></span>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Надіслати відгук" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" asp-route-id="@ViewBag.Productsid">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}