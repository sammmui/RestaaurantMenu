@model RestaurantMenuDomain.Model.Review

@{
    ViewData["Title"] = "Додати відгук";
}

<div class="full-screen-wrapper">
    <div class="form-container">
        <h1 class="page-title">Ваш відгук</h1>
        
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
           
            <input type="hidden" name="Productsid" value="@ViewBag.Productsid" />
            
            @* Автоматична дата *@
            <input type="hidden" asp-for="Data" value="@DateTime.Now.ToString("yyyy-MM-dd")" />

            <div class="form-group">
                <label class="control-label">Оцінка (1-5)</label>
                <select asp-for="Mark" class="custom-input">
                    <option value="5">5 ★ ★ ★ ★ ★ (Відмінно)</option>
                    <option value="4">4 ★ ★ ★ ★ (Добре)</option>
                    <option value="3">3 ★ ★ ★ (Середньо)</option>
                    <option value="2">2 ★ ★ (Погано)</option>
                    <option value="1">1 ★ (Жахливо)</option>
                </select>
                <span asp-validation-for="Mark" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label class="control-label">Ваш коментар</label>
                <textarea asp-for="Comment" class="custom-input" rows="4" placeholder="Поділіться враженнями про страву..."></textarea>
                <span asp-validation-for="Comment" class="text-danger"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-submit">Опублікувати</button>
                <a asp-action="Index" asp-route-id="@ViewBag.Productsid" class="btn-cancel">Скасувати</a>
            </div>
        </form>
    </div>
</div>

<style>
    body {
        background-color: #0D0D0F !important;
        color: white;
        font-family: 'Playfair Display', serif;
    }

    .full-screen-wrapper {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 20px;
    }

    .form-container {
        background-color: #161618;
        padding: 40px;
        border-radius: 20px;
        width: 100%;
        max-width: 500px;
        border: 1px solid #222;
        box-shadow: 0 20px 50px rgba(0,0,0,0.5);
    }

    .page-title {
        color: #E6D5C7;
        text-align: center;
        margin-bottom: 30px;
        font-size: 32px;
    }

    .form-group {
        margin-bottom: 25px;
    }

    .control-label {
        display: block;
        margin-bottom: 10px;
        color: #888;
        font-size: 14px;
        text-transform: uppercase;
    }

    .custom-input {
        width: 100%;
        background-color: #0D0D0F;
        border: 1px solid #333;
        border-radius: 10px;
        padding: 12px;
        color: white;
        font-family: inherit;
        transition: 0.3s;
    }

        .custom-input:focus {
            border-color: #E6D5C7;
            outline: none;
            box-shadow: 0 0 10px rgba(230, 213, 199, 0.2);
        }

    .form-actions {
        display: flex;
        flex-direction: column;
        gap: 15px;
        margin-top: 30px;
    }

    .btn-submit {
        background-color: #E6D5C7;
        color: #0D0D0F;
        border: none;
        padding: 15px;
        border-radius: 12px;
        font-weight: bold;
        cursor: pointer;
        transition: 0.3s;
    }

        .btn-submit:hover {
            background-color: white;
            transform: translateY(-2px);
        }

    .btn-cancel {
        text-align: center;
        color: #666;
        text-decoration: none;
        font-size: 14px;
    }

        .btn-cancel:hover {
            color: #ff4d4d;
        }
</style>