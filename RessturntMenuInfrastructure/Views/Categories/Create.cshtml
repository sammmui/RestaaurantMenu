@model RestaurantMenuDomain.Model.Category

@{
    ViewData["Title"] = "Нова категорія";
}

<div class="login-page-wrapper">
    <div class="login-card">
        <h2 class="login-title">Нова категорія</h2>

        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-row">
                <label asp-for="Name">Назва категорії</label>
                <div class="input-container">
                    <input asp-for="Name" class="custom-input" placeholder="Наприклад: Суші,..." />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
            </div>

            <div class="button-row" style="display: flex; justify-content: space-between; align-items: center; margin-top: 40px;">
                <a asp-action="Index" class="back-link">← Назад до меню</a>
                <button type="submit" class="login-submit-btn">Створити</button>
            </div>
        </form>
    </div>
</div>

<style>
    html, body { background-color: #0D0D0F !important; color: white; font-family: 'Playfair Display', serif; }

    .login-page-wrapper { display: flex; justify-content: center; align-items: center; min-height: 80vh; padding: 20px; }
    .login-card { background-color: #161618; padding: 50px; border-radius: 40px; width: 100%; max-width: 500px; box-shadow: 0 20px 50px rgba(0,0,0,0.6); border: 1px solid #222; }
    .login-title { color: #E6D5C7; text-align: center; margin-bottom: 40px; font-size: 32px; letter-spacing: 2px; }
    .form-row { margin-bottom: 25px; }
    .form-row label { display: block; color: #E6D5C7; margin-bottom: 10px; font-size: 16px; opacity: 0.8; }
    .custom-input { width: 100%; background-color: #0D0D0F; border: 1px solid #333; border-radius: 15px; padding: 15px; color: white; outline: none; transition: 0.3s; box-sizing: border-box; }
    .custom-input:focus { border-color: #E6D5C7; box-shadow: 0 0 10px rgba(230, 213, 199, 0.1); }
    .login-submit-btn { background-color: #E6D5C7; color: #161618; border: none; padding: 12px 35px; border-radius: 25px; font-weight: bold; cursor: pointer; transition: 0.3s; font-size: 16px; }
    .login-submit-btn:hover { background-color: #fff; transform: scale(1.05); }
    .back-link { color: #666; text-decoration: none; font-size: 14px; transition: 0.3s; }
    .back-link:hover { color: #E6D5C7; }
    .text-danger { color: #ff4d4d; font-size: 13px; margin-top: 5px; display: block; }
</style>