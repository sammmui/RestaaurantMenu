@model RestaurantMenuDomain.Model.Category

@{
    ViewData["Title"] = "Видалення";
}

<div class="login-page-wrapper">
    <div class="login-card" style="border-color: #401111;">
        <h2 class="login-title" style="color: #ff4d4d;">Видалити розділ?</h2>
        
        <div style="text-align: center; margin-bottom: 30px;">
            <p style="color: #888; font-size: 18px;">Ви впевнені, що хочете видалити категорію:</p>
            <h3 style="color: white; font-family: serif; font-size: 32px; margin: 10px 0;">@Model.Name</h3>
            <p style="color: #ff4d4d; font-size: 13px; margin-top: 20px;">
                ⚠️ Увага: всі страви у цьому розділі також будуть видалені!
            </p>
        </div>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <div class="button-row" style="display: flex; justify-content: space-between; align-items: center;">
                <a asp-action="Index" class="back-link">Ні, повернутися</a>
                <button type="submit" class="login-submit-btn" style="background-color: #ff4d4d; color: white;">Так, видалити</button>
            </div>
        </form>
    </div>
</div>

<style>

html, body {
    margin: 0;
    padding: 0;
    background-color: #0D0D0F !important;
    min-height: 100vh;
}


.full-screen-wrapper {
    background-color: #0D0D0F;
    min-height: 100vh;
    width: 100%;
    padding: 40px 0;
}
    .login-page-wrapper { display: flex; justify-content: center; align-items: center; min-height: 80vh; background-color: #0D0D0F; }
    .login-card { background-color: #161618; padding: 50px; border-radius: 40px; width: 100%; max-width: 500px; border: 1px solid #222; text-align: center; }
    .login-title { font-family: 'Playfair Display', serif; margin-bottom: 20px; }
    .login-submit-btn { border: none; padding: 12px 30px; border-radius: 25px; font-weight: bold; cursor: pointer; transition: 0.3s; }
    .login-submit-btn:hover { transform: scale(1.05); opacity: 0.9; }
    .back-link { color: #666; text-decoration: none; }
</style>