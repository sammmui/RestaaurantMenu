@model RestaurantMenuDomain.Model.Product

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Montserrat:wght@300;400&display=swap" rel="stylesheet">

<div class="menu-list-section details-view-wrapper">
    <div class="promo-grid single-item-container">
        
        
        <div class="promo-image-wrapper">
            <div class="image-box">
                <img src="@Model.Img" alt="@Model.Name" class="main-dish-img" />
                
                @if (User.IsInRole("Admin"))
                {
                    <div class="admin-actions">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-edit-premium">
                            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                            </svg>
                            EDIT PRODUCT
                        </a>
                    </div>
                }
            </div>
        </div>

       
        <div class="promo-info">
            <h1 class="promo-name">@Model.Name</h1>
            
            <div class="price-block">
                <span class="old-price">Description</span>
                
                <p class="description-body">@Model.Description</p> 
            </div>

            <div class="price-details">
                <span class="current-price">@Model.Price.ToString("0") грн</span>
                <span class="unit-label">/ 1 шт</span>
            </div>

            <div class="promo-footer">
                <a asp-action="Index" asp-route-id="@Model.Categoriesid" class="more-link">← back to menu</a>
            </div>
        </div>

    </div>
</div>

<style>
    
    .details-view-wrapper {
        background-color: #2D2D2D;
        min-height: 100vh;
        width: 100vw;
        margin-left: calc(-50vw + 50%);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 5%;
        box-sizing: border-box;
    }

    .single-item-container {
        display: flex;
        align-items: center;
        gap: 80px;
        max-width: 1400px;
        margin: 0 auto;
    }

    /* Стилі для фото */
    .promo-image-wrapper {
        flex: 0 0 450px;
        height: 450px;
    }

    .main-dish-img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        filter: drop-shadow(0 20px 40px rgba(0,0,0,0.8));
    }

   
    .promo-info {
        flex: 1;
        color: #f8ccc3; 
        font-family: 'KaiseiOpti', serif !important;
    }

    .promo-name {
        font-size: 4rem;
        margin-bottom: 20px;
        line-height: 1.1;
    }

    .description-body {
        font-size: 1.2rem;
        line-height: 1.6;
        opacity: 0.8;
        margin-bottom: 30px;
        max-width: 500px;
    }

    .current-price {
        color: #f8ccc3; 
        font-size: 2.8rem;
    }

    .unit-label {
        font-size: 1.2rem;
        color: #555;
        margin-left: 10px;
    }

    /* Кнопки */
    .promo-footer {
        margin-top: 40px;
    }

    .more-link {
        color: #f8ccc3;
        text-decoration: none;
        font-size: 1.4rem;
        opacity: 0.7;
        transition: 0.3s;
    }

    .more-link:hover {
        opacity: 1;
        text-decoration: underline;
    }

    .admin-actions {
        margin-top: 20px;
        text-align: center;
    }

    .btn-edit-premium {
        color: #555;
        text-decoration: none;
        font-size: 12px;
        letter-spacing: 1px;
        border: 1px solid #333;
        padding: 5px 15px;
        border-radius: 20px;
        transition: 0.3s;
    }

    .btn-edit-premium:hover {
        color: #f8ccc3;
        border-color: #f8ccc3;
    }

   
</style>