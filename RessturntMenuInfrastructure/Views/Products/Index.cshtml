@model IEnumerable<RestaurantMenuDomain.Model.Product>

@{
    ViewData["Title"] = "Menu - " + ViewBag.CategoryName;
}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">

<div class="full-screen-wrapper">
    <div class="product-page">
        <div class="menu-header" style="display: flex; flex-direction: column; align-items: center; gap: 20px; margin-bottom: 50px;">
        <h1 class="category-title" style="margin: 0;">@ViewBag.CategoryName</h1>
        
       @if (User.IsInRole("Admin"))
        {
            <div class="admin-top-panel" style="text-align: center; margin-bottom: 30px;">
                <a asp-action="Create" asp-route-categoryId="@ViewBag.CategoryId" class="btn-add-product">
                    + Додати нову страву
                </a>
            </div>
        }
        
    </div>
       <div class="menu-layout">
    <div class="product-list">
        @foreach (var item in Model)
        {
            <div class="product-row">
                <div class="item-main">
                    <span class="item-name">@item.Name</span>
                    <span class="dots"></span>
                    <span class="item-price">@item.Price.ToString("0") грн</span> 
                </div>
                       
                <div class="item-actions">
                    <a asp-action="Details" asp-route-id="@item.Id" class="action-link">details</a>
                    <span class="separator">|</span>
                    <a asp-controller="Reviews" 
                       asp-action="Index" 
                       asp-route-id="@item.Id" 
                       asp-route-catId="@ViewBag.CategoryId" 
                       class="action-link highlight">залишити відгук</a>

                    @* --- БЛОК АДМІНІСТРАТОРА --- *@
                    @if (User.IsInRole("Admin"))
                    {
                        <span class="separator">|</span>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="admin-link edit">edit</a>
                        <span class="separator">/</span>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="admin-link delete">delete</a>
                        <div style="margin: 20px 0;">
       
    </div>
                    }
                </div>
            </div>
        }
    </div>
</div>
                
                <div class="back-nav">
                    <a asp-controller="Categories" asp-action="Index" class="back-link">← back to menu</a>
                </div>
            </div>

            <div class="menu-visual">
    @{
        
        string categoryImage = (ViewBag.CategoryName as string)?.ToLower() ?? "default";
    }
    
</div>
  </div>
    


<style>
    html, body {
        background-color: #212023 !important;
        margin: 0 !important;
        padding: 0 !important;
        min-height: 100%;
       
        scrollbar-color: #444 #212023; 
    }



.full-screen-wrapper {
    overflow-x: hidden !important;
    margin-bottom: 0 !important;
    padding-bottom: 0 !important;
}


body {
    margin-bottom: 0 !important;
    padding-bottom: 0 !important;
    height: 100vh;
}
    .item-price {
        font-family: 'Playfair Display', serif;
        font-size: 1.8rem;
        color: #D4B6AC; 
        white-space: nowrap;
    }

    .dots {
        flex: 1;
        border-bottom: 2px dotted rgba(212, 182, 172, 0.3); 
        margin: 0 15px;
        height: 1.4rem;
    }
    
    
    .full-screen-wrapper {
        background-color: #1E1E1E;
        margin-left: calc(-50vw + 50%);
        margin-right: calc(-50vw + 50%);
        width: 100vw;
        min-height: 100vh;
        color: #F5E6E0;
    }
    .product-page { max-width: 1200px; margin: 0 auto; padding: 60px 20px; }
    .category-title { font-family: 'Playfair Display', serif; font-size: 5rem; margin-bottom: 60px; font-weight: 400; }
    .menu-layout { display: flex; justify-content: space-between; gap: 60px; }
    .product-list { flex: 1; }
    .product-row { margin-bottom: 40px; display: flex; flex-direction: column; }
    .item-main { display: flex; align-items: baseline; width: 100%; }
    .item-name { font-family: 'Playfair Display', serif; font-size: 2rem; white-space: nowrap; }
    .item-actions { margin-top: 5px; font-size: 0.85rem; }
    .action-link { color: #888; text-decoration: none; transition: 0.3s; }
    .action-link.highlight { color: #D4B6AC; }
    .separator { color: #444; margin: 0 5px; }
    .menu-visual { flex: 0 0 40%; display: flex; justify-content: center; align-items: flex-start; }
    .menu-visual img { width: 100%; max-width: 450px; filter: drop-shadow(0 20px 40px rgba(0,0,0,0.6)); }

    .back-link { color: #666; text-decoration: none; font-size: 0.9rem; text-transform: uppercase; }
   .category-title { 
        font-family: 'Playfair Display', serif; 
        font-size: 5rem; 
        margin-bottom: 20px; 
        font-weight: 400; 
    }

   
    .admin-link {
        font-size: 0.9rem;
        text-transform: lowercase;
        text-decoration: none;
        transition: 0.3s;
    }

   
    .admin-link.edit {
        color: #d4af37; 
        opacity: 0.7;
    }

   
    .admin-link.delete {
        color: #8b0000;
        opacity: 0.7;
    }

    .admin-link:hover {
        opacity: 1;
        text-decoration: underline;
    }

    
    .separator {
        color: #444;
        margin: 0 5px;
    }
    
    .btn-add-product {
        display: inline-block;
        color: #E6D5C7; 
        text-decoration: none;
        border: 1px solid #E6D5C7;
        padding: 10px 25px;
        border-radius: 30px;
        font-family: serif;
        font-size: 16px;
        transition: 0.3s all ease;
        background: transparent;
    }

    .btn-add-product:hover {
        background-color: #E6D5C7;
        color: #161618; 
        transform: translateY(-2px);
    }


    .menu-layout { 
        display: flex; 
        justify-content: space-between; 
        align-items: flex-start; 
        gap: 0; 
        margin-top: -10px; 
    }

    .product-list { 
        flex: 0 0 45%; 
        padding-top: 20px; 
    }

    .menu-visual { 
        flex: 0 0 55%; 
        display: flex; 
        justify-content: flex-end; 
        position: relative;
       
        margin-right: -100px; 
    }

    .menu-visual img { 
        width: 120%; 
        max-width: 900px; 
        height: auto; 
        filter: drop-shadow(-40px 50px 70px rgba(0,0,0,0.9)); 
      
        transform: translateY(20px) translateX(30px);
    }

    .item-name { 
        font-family: 'Playfair Display', serif; 
        font-size: 2.2rem; 
        white-space: nowrap; 
    }

  
    .full-screen-wrapper {
        overflow-x: hidden;
    }
    
    .btn-add-product {
        display: inline-block;
        color: #E6D5C7; 
        text-decoration: none;
        border: 1px dashed #E6D5C7;
        padding: 10px 25px;
        border-radius: 20px;
        font-family: 'Playfair Display', serif;
        font-size: 16px;
        transition: 0.3s;
    }

    .btn-add-product:hover {
        background-color: rgba(230, 213, 199, 0.1);
        border-style: solid;
        color: white;
    }

    .admin-link {
        color: #E6D5C7 !important; 
        text-decoration: none;
        font-size: 13px;
    }
</style>
